{
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml; charset=utf-8" }]
    },
    {
      "source": "/rss.xml",
      "headers": [{ "key": "Content-Type", "value": "application/rss+xml; charset=utf-8" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "script-src 'self' 'unsafe-inline' https://pagead2.googlesyndication.com https://t1.kakaocdn.net https://developers.kakao.com https://fonts.googleapis.com; default-src *; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src *;" }
      ]
    }
  ],
