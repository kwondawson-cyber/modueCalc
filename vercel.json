{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "script-src 'self' 'unsafe-inline' https://pagead2.googlesyndication.com https://t1.kakaocdn.net https://developers.kakao.com https://fonts.googleapis.com; default-src *; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src *;"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/salary", "destination": "/salary.html" },
    { "source": "/age", "destination": "/age.html" },
    { "source": "/retirement", "destination": "/retirement.html" },
    { "source": "/unemployment", "destination": "/unemployment.html" },
    { "source": "/loan", "destination": "/loan.html" },
    { "source": "/dday", "destination": "/dday.html" },
    { "source": "/bmi", "destination": "/bmi.html" },
    { "source": "/bmr", "destination": "/bmr.html" },
    { "source": "/realestate", "destination": "/realestate.html" },
    { "source": "/acquisition", "destination": "/acquisition.html" },
    { "source": "/capital_gains", "destination": "/capital_gains.html" },
    { "source": "/gift_tax", "destination": "/gift_tax.html" },
    { "source": "/rent_conversion", "destination": "/rent_conversion.html" },
    { "source": "/pregnancy", "destination": "/pregnancy.html" },
    { "source": "/savings", "destination": "/savings.html" },
    { "source": "/exchange", "destination": "/exchange.html" },
    { "source": "/inflation", "destination": "/inflation.html" }
  ]
}
